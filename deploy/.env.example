# Replace with your Docker Hub username/repo
BACKEND_IMAGE=<dockerhub-id>/gachi-be:latest
AI_IMAGE=<dockerhub-id>/gachi-ai:latest

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Use stage profile when you need Swagger exposure
SPRING_PROFILES_ACTIVE=prod
SWAGGER_ENABLED=false
SWAGGER_BASIC_AUTH_FILE=./secrets/swagger_htpasswd.txt
SWAGGER_TLS_CERT_FILE=./secrets/swagger_tls.crt
SWAGGER_TLS_KEY_FILE=./secrets/swagger_tls.key
SWAGGER_TLS_MODE=letsencrypt_ip
SWAGGER_TLS_IP=
SWAGGER_TLS_COMMON_NAME=

DB_URL=jdbc:postgresql://db:5432/gachi
DB_USERNAME=gachi
DB_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# SMTP (required when AUTH_EMAIL_NOOP_ALLOWED=false)
SPRING_MAIL_HOST=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PASSWORD_SECRET_FILE=./secrets/spring_mail_password.example.txt
SPRING_MAIL_PORT=587
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_USERNAME=

OPENAI_API_KEY=

AUTH_EMAIL_FROM_ADDRESS=
AUTH_EMAIL_NOOP_ALLOWED=false
AUTH_EMAIL_REPLY_TO=
AUTH_EMAIL_SUBJECT="[GACHI] Email verification code"
AUTH_RATE_LIMIT_EMAIL_HMAC_SECRET=replace-with-strong-random-secret
AUTH_RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_IMAGE_PREFIX=images

# Let's Encrypt account email (required for production operations)
CERTBOT_EMAIL=admin@example.com
