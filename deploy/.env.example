# Replace with your Docker Hub username/repo
BACKEND_IMAGE=<dockerhub-id>/gachi-be:latest
AI_IMAGE=<dockerhub-id>/gachi-ai:latest

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Use stage profile when you need Swagger exposure
SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:postgresql://db:5432/gachi
DB_USERNAME=gachi
DB_PASSWORD=

OPENAI_API_KEY=

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_IMAGE_PREFIX=images
AUTH_RATE_LIMIT_EMAIL_HMAC_SECRET=replace-with-strong-random-secret
AUTH_RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1

# TLS placeholders (fill when domain is purchased)
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
